# ===== 服务配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库 =====
DB_PATH=./quiz.db

# ===== 安全（生产环境务必修改）=====
JWT_SECRET=change-me-to-a-random-string-in-production

# ===== 管理员默认密码 =====
# 初始密码的 bcrypt 哈希值，生产环境部署后应通过管理后台修改
# 默认密码: admin-quiz-2024
ADMIN_DEFAULT_PASSWORD=admin-quiz-2024

# ===== 上传文件 =====
UPLOAD_DIR=./uploads
